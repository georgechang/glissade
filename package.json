{
  "name": "glissade-monorepo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=22" },
  "workspaces": ["packages/shared", "packages/scroll-engine", "packages/extension"],
  "scripts": {
    "build": "npm run build --workspace=@glissade/shared --workspace=@glissade/scroll-engine --if-present && npm run build --workspace=@glissade/extension --if-present",
    "dev": "npm run dev --workspace=@glissade/extension",
    "zip": "npm run zip --workspace=@glissade/extension",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "happy-dom": "^15.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
