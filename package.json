{
  "name": "page-capture-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "workspaces": ["packages/shared", "packages/scroll-engine"],
  "scripts": {
    "build": "npm run build --workspace=@page-capture/shared --workspace=@page-capture/scroll-engine --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "happy-dom": "^15.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
