{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@page-capture/shared": ["packages/shared/src/index.ts"],
      "@page-capture/scroll-engine": ["packages/scroll-engine/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "vitest.config.ts"
  ],
  "comment": "The extension self-typechecks via WXT (its own tsconfig has DOM/chrome libs + browser-only @types). Root typecheck covers shared + scroll-engine only.",
  "exclude": [
    "node_modules",
    "packages/extension/**",
    "**/dist/**",
    "**/.wxt/**",
    "**/.output/**"
  ]
}
